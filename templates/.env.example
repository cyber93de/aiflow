# aiflow secrets — copy to .env (gitignored) and fill in. Loaded by `aiflow shell`/`aiflow ralph`.

# --- Remote host token (set the one matching .aiflow/config.json -> remote.type) ---
# TOKEN-BASED ONLY (no OAuth). Give the token the scopes for repo + issues + PRs/MRs.
# GitHub: PAT (GitHub MCP + gh + Actions).
GITHUB_TOKEN=
# GitLab (gitlab.com or self-managed): personal access token, api scope (used by glab).
GITLAB_TOKEN=
# Bitbucket: app password / token (REST API).
BITBUCKET_TOKEN=
# Custom host (Forgejo/Gitea/GitLab-EE/…): the env var name is set in config -> remote.tokenEnv.
# Default name below; rename to match your config if you changed it.
GIT_REMOTE_TOKEN=

# --- Claude access (matches .aiflow/config.json -> claude.auth; both work, OAuth wins if both set) ---
# apikey) Anthropic API key (pay-per-use):        https://console.anthropic.com
ANTHROPIC_API_KEY=
# oauth)  Claude Code OAuth token (uses your plan): run `claude setup-token`
CLAUDE_CODE_OAUTH_TOKEN=

# --- context7 MCP (optional; works keyless, key raises rate limits) ---
CONTEXT7_API_KEY=

# --- Cost routing (optional; claude-code-router via 'aiflow shell --router') ---
# Add only the providers you route to. Keys can also live directly in
# ~/.claude-code-router/config.json (never committed). See README §9.
# Ollama (local) needs NO key — configured in .aiflow/config.json -> ollama.
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# --- Application under test (read by generated http/*.http files + BDD E2E tests) ---
# Host/port of the locally running app and a NON-PRODUCTION test account.
# VS Code REST Client reads these via {{$dotenv APP_HOST}}; for IntelliJ mirror the
# credentials into the gitignored http-client.private.env.json.
APP_HOST=localhost
APP_PORT=8080
TEST_USERNAME=
TEST_PASSWORD=

# --- Ralph loop tuning ---
RALPH_MAX_ITERATIONS=50
RALPH_TIMEOUT_SECONDS=3600
# Permission mode for headless runs: acceptEdits | bypassPermissions
RALPH_PERMISSION_MODE=acceptEdits
